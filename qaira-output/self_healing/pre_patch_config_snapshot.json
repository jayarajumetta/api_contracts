{
  "agent": {
    "name": "qaira-semantic-compiler",
    "mode": "public-repo-trial"
  },
  "paths": {
    "source_dir": "/workspace/source-repo",
    "output_dir": "/output",
    "learning_dir": "/learning"
  },
  "repository_input": {
    "enabled": true,
    "repo_url_env": "QAIRA_REPO_URL",
    "branch": "",
    "clone_dir": "/workspace/source-repo",
    "token_env": "GIT_TOKEN",
    "username_env": "GIT_USERNAME"
  },
  "logging": {
    "console": true,
    "jsonl_trace": true,
    "redact_secrets": true,
    "progress_every_items": 50
  },
  "scan": {
    "max_file_size_kb": 4096,
    "include_extensions": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx",
      ".py",
      ".java",
      ".cs",
      ".json",
      ".yaml",
      ".yml"
    ],
    "exclude_dirs": [
      "node_modules",
      ".git",
      "dist",
      "build",
      "coverage",
      ".next",
      ".cache",
      "playwright-report",
      "test-results",
      "tmp",
      "logs"
    ],
    "exclude_files": [
      "*.map",
      "*.lock",
      "*.png",
      "*.jpg",
      "*.jpeg",
      "*.gif",
      "*.mp4",
      "*.zip",
      "*.tar",
      "*.gz"
    ]
  },
  "runtime": {
    "fail_open": true,
    "agent_timeout_seconds": 900,
    "continue_on_error": true,
    "write_agent_io": true
  },
  "auto_iteration": {
    "enabled": true,
    "max_iterations": 3,
    "stop_when_quality_passes": true,
    "min_score_percent": 90,
    "apply_known_remediations": true,
    "preserve_best_iteration": true,
    "compare_against_previous_iteration": true
  },
  "enterprise_loop": {
    "enabled": true,
    "clone_before_iterations": true,
    "final_generation_after_iterations": true,
    "llm_once_per_iteration": true,
    "llm_only_when_below_threshold": false,
    "max_llm_calls_per_run": 1,
    "single_context_file": "runtime/iteration_context.json",
    "compact_context_only": true,
    "max_context_chars": 12000,
    "apply_llm_delta_code_generation": true,
    "delta_patch_mode": "plan_only",
    "commit_generated_artifacts": true,
    "commit_delta_patches": true
  },
  "llm_review": {
    "enabled": true,
    "execute_network_calls": true,
    "provider": "openai",
    "model": "gpt-4.1-mini",
    "api_key_env": "OPENAI_API_KEY",
    "endpoint": "https://api.openai.com/v1/chat/completions",
    "timeout_seconds": 20,
    "max_retries": 0,
    "fail_open": true,
    "max_prompt_chars": 12000,
    "calls_per_run": 1,
    "send_single_iteration_context": true
  },
  "llm": {
    "enabled": true,
    "execute_network_calls": true,
    "provider": "openai",
    "model": "gpt-4.1-mini",
    "api_key_env": "OPENAI_API_KEY",
    "endpoint": "https://api.openai.com/v1/chat/completions",
    "timeout_seconds": 20,
    "max_retries": 0,
    "fail_open": true,
    "max_prompt_chars": 12000
  },
  "agents": {
    "source_repo_clone": true,
    "source_detection": true,
    "repository_index": true,
    "route_discovery": true,
    "body_discovery": true,
    "path_param_discovery": true,
    "query_param_discovery": true,
    "header_discovery": true,
    "param_type_discovery": true,
    "validation_schema_discovery": true,
    "import_graph": true,
    "service_graph": true,
    "schema_attachment": true,
    "service_body_field_extraction": true,
    "db_write_field_extraction": true,
    "service_body_propagation": true,
    "inferred_schema_registry": true,
    "required_field_confidence": true,
    "response_discovery": true,
    "contract_builder": true,
    "relationship_discovery": true,
    "test_generation": true,
    "quality_gate": true,
    "artifact_manifest": true
  },
  "pattern_establishment": {
    "enabled": true,
    "service_body_field_extraction": true,
    "db_write_field_extraction": true,
    "service_body_propagation": true,
    "inferred_schema_registry": true,
    "min_confidence": 0.55,
    "relaxed_body_detection": true
  },
  "contract_quality": {
    "enabled": true,
    "separate_declared_and_inferred_schema_metrics": true,
    "generate_required_field_confidence": true,
    "generate_negative_tests": true,
    "generate_edge_tests": true
  },
  "artifact_quality": {
    "enhanced_openapi_docs": true,
    "include_examples": true,
    "include_payload_references": true,
    "include_markdown_docs": true,
    "include_data_reference_file": true,
    "postman_quality": {
      "enabled": true,
      "include_status_assertions": true,
      "include_json_body_assertions": true,
      "include_schema_presence_assertions": true,
      "include_extractors": true,
      "include_negative_tests": true,
      "include_edge_tests": true,
      "use_collection_variables": true
    }
  },
  "quality_gate": {
    "min_score_percent": 90,
    "fail_open_below_threshold": true
  },
  "test_generation": {
    "types": [
      "postman",
      "curl",
      "qaira",
      "playwright_api"
    ],
    "base_url_variable": "{{baseUrl}}",
    "default_base_url_variable": "{{baseUrl}}",
    "use_data_references": true,
    "use_param_references": true,
    "generate_extractors": true,
    "generate_negative_tests": true,
    "generate_edge_tests": true
  },
  "self_healing": {
    "enabled": true,
    "evaluate_each_agent": true,
    "llm_advisor_enabled": true,
    "llm_call_policy": "once_per_iteration_if_below_threshold_or_agent_failed",
    "max_llm_calls_per_run": 1,
    "generate_agent_specific_delta_plan": true,
    "generate_agent_patch_files": true,
    "apply_generated_agent_code": false,
    "safe_patch_only": true,
    "allowed_patch_agents": [
      "RouteDiscoveryAgent",
      "BodyDiscoveryAgent",
      "ParamsDiscoveryAgent",
      "ParamTypeDiscoveryAgent",
      "ImportGraphAgent",
      "ServiceGraphAgent",
      "ServiceBodyFieldAgent",
      "DbWriteFieldAgent",
      "ServiceBodyPropagationAgent",
      "InferredSchemaRegistryAgent",
      "TestGenerationAgent",
      "QualityGateAgent"
    ]
  },
  "patch_library": {
    "enabled": true,
    "apply_patches_during_iteration": true,
    "max_patches_per_iteration": 5,
    "min_confidence": 0.6,
    "allow_source_file_modification": false,
    "allow_runtime_config_mutation": true,
    "allow_pattern_registry_mutation": true,
    "require_pre_post_score_tracking": true,
    "rollback_if_score_drops": true,
    "rollback_drop_tolerance": 1.0
  },
  "pattern_registry": {
    "body_aliases": [
      "body",
      "payload",
      "data",
      "input",
      "dto",
      "requestBody",
      "form",
      "values"
    ],
    "id_field_hints": [
      "id",
      "_id",
      "uuid",
      "guid"
    ],
    "required_field_hints": [
      "name",
      "title",
      "email",
      "password",
      "username",
      "type",
      "status"
    ]
  },
  "react_safety": {
    "enabled": true,
    "strict_json_transport": true,
    "escape_prompt_payloads": true,
    "tolerate_malformed_json": true,
    "fail_open_on_parse_error": true,
    "save_raw_llm_text": true
  },
  "branch_strategy": {
    "clone_base_branch": "main",
    "work_branch": "develop",
    "create_work_branch_if_missing": true,
    "push_work_branch": "develop",
    "pr_base_branch": "main"
  },
  "git_push": {
    "enabled": true,
    "execute_git": true,
    "repo_url": "",
    "target_branch": "develop",
    "create_branch": true,
    "create_branch_prefix": "qaira-agent",
    "username_env": "GIT_USERNAME",
    "token_env": "GIT_TOKEN",
    "commit_message": "chore: add generated QAira API contracts and tests",
    "copy_artifacts_to": [
      "generated/",
      "final/",
      "summary/",
      "quality/",
      "analysis/",
      "codegen/",
      "docs/",
      "self_healing/",
      "repo/"
    ],
    "push": true,
    "fail_open": true
  },
  "git_finalization": {
    "enabled": false,
    "execute_git": false,
    "push": false
  },
  "pull_request": {
    "enabled": true,
    "execute_network_calls": true,
    "provider": "github",
    "base_branch": "main",
    "title": "QAira generated API contracts and tests",
    "body": "Automated QAira semantic compiler output update.",
    "token_env": "GIT_TOKEN",
    "fail_open": true
  },
  "git_diagnostics": {
    "enabled": true,
    "require_git_binary": true,
    "write_preflight_report": true
  },
  "compatibility": {
    "config_override_optional": true,
    "default_config_used_when_no_config_supplied": true,
    "public_repo_trial_defaults_enabled": true,
    "override_config_loaded": "/app/config/config.example.yaml"
  }
}